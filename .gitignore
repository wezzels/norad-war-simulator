# Godot 4.x .gitignore

# Godot-specific ignores
.import/
export/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV)
*.translation

# Qt SCons backup file
*.*.swp

# Qt Creator project files
*.creator
*.creator.user
*.config

# Mono-specific ignores
.mono/
data obj/
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Rider
.idea/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build files
*.exe
*.x86_64
*.x86
*.apk
*.aab
*.ipa
*.zip
*.pck

# Steam integration (if using Steamworks)
*.steam_appid.txt

# Project-specific
reference/norad-war-simulator.pck
export/
