; Game Theme
; Consistent styling for NORAD War Simulator

[gd_resource type="Theme" load_steps=4 format=3]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_button_normal"]
bg_color = Color(0.15, 0.15, 0.2, 1.0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.3, 0.35, 0.45, 1.0)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_button_hover"]
bg_color = Color(0.2, 0.22, 0.28, 1.0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.4, 0.5, 0.7, 1.0)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_button_pressed"]
bg_color = Color(0.1, 0.1, 0.15, 1.0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.2, 0.25, 0.35, 1.0)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4

[resource]
default_base_scale = 1.0

Button/constants/h_separation = 8
Button/constants/v_separation = 4
Button/colors/font_color = Color(0.9, 0.92, 0.95, 1.0)
Button/colors/font_hover_color = Color(1.0, 1.0, 1.0, 1.0)
Button/colors/font_pressed_color = Color(0.8, 0.82, 0.85, 1.0)
Button/colors/font_disabled_color = Color(0.5, 0.5, 0.5, 1.0)
Button/styles/normal = SubResource("StyleBoxFlat_button_normal")
Button/styles/hover = SubResource("StyleBoxFlat_button_hover")
Button/styles/pressed = SubResource("StyleBoxFlat_button_pressed")
Button/styles/disabled = SubResource("StyleBoxFlat_button_normal")

Label/colors/font_color = Color(0.9, 0.92, 0.95, 1.0)
Label/colors/font_shadow_color = Color(0.0, 0.0, 0.0, 0.5)
Label/constants/shadow_offset_x = 1
Label/constants/shadow_offset_y = 1

Panel/styles/panel = SubResource("StyleBoxFlat_button_normal")

ProgressBar/colors/font_color = Color(0.9, 0.92, 0.95, 1.0)
ProgressBar/colors/font_outline_color = Color(0.0, 0.0, 0.0, 1.0)

Slider/styles/slider = SubResource("StyleBoxFlat_button_normal")
Slider/styles/grabber_area = SubResource("StyleBoxFlat_button_hover")

OptionButton/styles/normal = SubResource("StyleBoxFlat_button_normal")
OptionButton/styles/hover = SubResource("StyleBoxFlat_button_hover")
OptionButton/styles/pressed = SubResource("StyleBoxFlat_button_pressed")

CheckBox/styles/normal = SubResource("StyleBoxFlat_button_normal")
CheckBox/styles/hover = SubResource("StyleBoxFlat_button_hover")
CheckBox/styles/pressed = SubResource("StyleBoxFlat_button_pressed")