; SCENE: Settings Menu
; Graphics, audio, and gameplay settings

[gd_scene load_steps=2 format=3 uid="uid://settings_menu"]

[ext_resource type="Script" path="res://scripts/ui/settings_menu.gd" id="1_settings"]

[node name="SettingsMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
