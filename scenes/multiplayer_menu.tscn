; SCENE: Multiplayer Menu
; Host/Join game selection screen

[gd_scene load_steps=3 format=3 uid="uid://multiplayer_menu"]

[ext_resource type="Script" path="res://scripts/ui/multiplayer_menu.gd" id="1_mp"]
[ext_resource type="Script" path="res://scripts/ui/button_animations.gd" id="2_anim"]

[node name="MultiplayerMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = preload("res://themes/game_theme.tres")
script = ExtResource("1_mp")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.02, 0.02, 0.04, 1.0)

[node name="PanelContainer" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -200.0
offset_right = 200.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.75, 0.4, 1.0)
theme_override_font_sizes/font_size = 28
text = "MULTIPLAYER"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="PlayerNameLabel" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "Player Name:"

[node name="PlayerNameEdit" type="LineEdit" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
placeholder_text = "Enter your name"

[node name="ServerIP" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2

[node name="Label" type="Label" parent="PanelContainer/VBoxContainer/ServerIP"]
layout_mode = 2
custom_minimum_size = Vector2(80, 0)
text = "Server IP:"

[node name="LineEdit" type="LineEdit" parent="PanelContainer/VBoxContainer/ServerIP"]
layout_mode = 2
size_flags_horizontal = 3
text = "127.0.0.1"
placeholder_text = "Server IP address"

[node name="ServerPort" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2

[node name="Label" type="Label" parent="PanelContainer/VBoxContainer/ServerPort"]
layout_mode = 2
custom_minimum_size = Vector2(80, 0)
text = "Port:"

[node name="SpinBox" type="SpinBox" parent="PanelContainer/VBoxContainer/ServerPort"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 1024.0
max_value = 65535.0
value = 7777.0

[node name="HSeparator2" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="HostButton" type="Button" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "HOST GAME"

[node name="JoinButton" type="Button" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "JOIN GAME"

[node name="BackButton" type="Button" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "BACK"

[node name="HSeparator3" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="Status" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.55, 0.6, 1.0)
text = ""
horizontal_alignment = 1