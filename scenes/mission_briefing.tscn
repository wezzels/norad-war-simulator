; SCENE: Mission Briefing
; Shows mission objectives and briefing before gameplay

[gd_scene load_steps=2 format=3 uid="uid://mission_briefing"]

[ext_resource type="Script" path="res://scripts/ui/mission_briefing.gd" id="1_briefing"]

[node name="MissionBriefing" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_briefing")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.1, 1)

[node name="Title" type="Label" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -200.0
offset_top = 20.0
offset_right = 200.0
offset_bottom = 50.0
text = "MISSION BRIEFING"
horizontal_alignment = 1

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 50.0
offset_top = 60.0
offset_right = -50.0
offset_bottom = -60.0

[node name="VBoxContainer" type="VBoxContainer" parent="Panel"]
layout_mode = 2

[node name="MissionNumber" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "Mission 1"
horizontal_alignment = 1

[node name="TitleLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "First Alert"
horizontal_alignment = 1

[node name="HSeparator" type="HSeparator" parent="Panel/VBoxContainer"]
layout_mode = 2

[node name="DescriptionLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "A single missile launch detected. Learn the basics."

[node name="BriefingEdit" type="TextEdit" parent="Panel/VBoxContainer"]
custom_minimum_size = Vector2(0, 150)
layout_mode = 2
size_flags_vertical = 3
readonly = true
wrap_mode = 1

[node name="ObjectivesLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "Objectives:
• Intercept incoming missiles
• Protect cities"

[node name="HSeparator2" type="HSeparator" parent="Panel/VBoxContainer"]
layout_mode = 2

[node name="UnlocksLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "Rewards:"

[node name="UnlocksContainer" type="VBoxContainer" parent="Panel/VBoxContainer"]
layout_mode = 2

[node name="StartButton" type="Button" parent="Panel"]
layout_mode = 1
anchors_preset = 6
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -150.0
offset_top = -50.0
offset_right = -10.0
offset_bottom = -10.0
text = "START MISSION"

[node name="BackButton" type="Button" parent="Panel"]
layout_mode = 1
anchors_preset = 6
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = 10.0
offset_top = -50.0
offset_right = 150.0
offset_bottom = -10.0
text = "BACK"