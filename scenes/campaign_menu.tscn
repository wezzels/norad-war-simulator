[node name="TechList" type="ItemList" parent="Panel/HBoxContainer/TechTreePanel/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="ButtonContainer" type="HBoxContainer" parent="."]
layout_mode = 1
