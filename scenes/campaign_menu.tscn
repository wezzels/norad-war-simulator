[node name="TechTreePanel" type="Panel" parent="Panel/HBoxContainer"]
custom_minimum_size = Vector2(300, 0)
layout_mode = 2
size_flags_horizontal = 3

[node name="VBox" type="VBoxContainer" parent="Panel/HBoxContainer/TechTreePanel"]
layout_mode = 2

[node name="TechTreeLabel" type="Label" parent="Panel/HBoxContainer/TechTreePanel/VBox"]
layout_mode = 2
