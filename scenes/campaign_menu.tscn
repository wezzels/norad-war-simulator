; SCENE: Campaign Menu
; Shows campaign progress, mission list, and tech tree

[gd_scene load_steps=2 format=3 uid="uid://campaign_menu"]

[ext_resource type="Script" path="res://scripts/ui/campaign_menu.gd" id="1_campaign"]

[node name="CampaignMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_campaign")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.1, 1)

[node name="Title" type="Label" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -200.0
offset_top = 20.0
offset_right = 200.0
offset_bottom = 50.0
text = "CAMPAIGN MODE"
horizontal_alignment = 1

[node name="ProgressLabel" type="Label" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -150.0
offset_top = 60.0
offset_right = 150.0
offset_bottom = 80.0
text = "Mission 0 / 8"
horizontal_alignment = 1

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 14
anchor_top = 0.5
anchor_bottom = 0.5
offset_left = 50.0
offset_top = -200.0
offset_right = -50.0
offset_bottom = 150.0

[node name="HBoxContainer" type="HBoxContainer" parent="Panel"]
layout_mode = 2

[node name="MissionsPanel" type="Panel" parent="Panel/HBoxContainer"]
custom_minimum_size = Vector2(300, 0)
layout_mode = 2
size_flags_horizontal = 3

[node name="VBox" type="VBoxContainer" parent="Panel/HBoxContainer/MissionsPanel"]
layout_mode = 2

[node name="MissionsLabel" type="Label" parent="Panel/HBoxContainer/MissionsPanel/VBox"]
layout_mode = 2
text = "MISSIONS"
horizontal_alignment = 1

[node name="MissionList" type="ItemList" parent="Panel/HBoxContainer/MissionsPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3
