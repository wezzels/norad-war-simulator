; SCENE: Achievements Screen
; Displays Steam achievements and game stats

[gd_scene load_steps=3 format=3 uid="uid://achievements_screen"]

[ext_resource type="Script" path="res://scripts/ui/achievements_screen.gd" id="1_ach"]
[ext_resource type="Script" path="res://scripts/ui/button_animations.gd" id="2_anim"]

[node name="AchievementsScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = preload("res://themes/game_theme.tres")
script = ExtResource("1_ach")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.02, 0.02, 0.04, 1.0)

[node name="PanelContainer" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -350.0
offset_top = -300.0
offset_right = 350.0
offset_bottom = 300.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.75, 0.4, 1.0)
theme_override_font_sizes/font_size = 28
text = "ACHIEVEMENTS & STATS"
horizontal_alignment = 1

[node name="Progress" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.55, 0.6, 1.0)
text = "Achievements: 0 / 18 (0.0%)"
horizontal_alignment = 1

[node name="OverallProgress" type="ProgressBar" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 20)
max_value = 18.0
value = 0.0

[node name="HSeparator" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="ScrollContainer" type="ScrollContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
size_flags_stretch_ratio = 3.0

[node name="AchievementList" type="VBoxContainer" parent="PanelContainer/VBoxContainer/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3

[node name="HSeparator2" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="Stats" type="VBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2

[node name="Label" type="Label" parent="PanelContainer/VBoxContainer/Stats"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Statistics"

[node name="StatsGrid" type="GridContainer" parent="PanelContainer/VBoxContainer/Stats"]
layout_mode = 2
columns = 2

[node name="HSeparator3" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 10)

[node name="BackButton" type="Button" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "BACK"