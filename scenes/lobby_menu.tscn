[node name="HSeparator3" type="HSeparator" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="ButtonContainer" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
