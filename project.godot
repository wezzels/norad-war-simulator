[layer_names]

3d_physics/layer_1="missiles"
3d_physics/layer_2="interceptors"
3d_physics/layer_3="satellites"
3d_physics/layer_4="cities"
3d_physics/layer_5="launch_sites"

rendering/textures/vram_compression/import_etc2_astc=true

textures/canvas_textures/default_texture_filter=0