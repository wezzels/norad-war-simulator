; Engine configuration file.
; It's best edited using Godot's built-in editor interface.
; If you're editing this file manually, you may want to run the editor
; with the --headless command-line argument.

config_version=5

[application]

config/name="NORAD War Simulator"
config/description="A cross-platform nuclear command simulation game"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "C#", "Standard Desktop 3D")
config/icon="res://icon.svg"

[autoload]

Main="*res://scripts/autoload/main.gd"
GameState="*res://scripts/autoload/game_state.gd"
Settings="*res://scripts/autoload/settings.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SteamManager="*res://scripts/systems/steam_manager.gd"
NetworkManager="*res://scripts/systems/network_manager.gd"
GameMode="*res://scripts/systems/game_mode.gd"
StateSync="*res://scripts/systems/state_sync.gd"
DefenseManager="*res://scripts/systems/defense_manager.gd"
ScenarioLoader="*res://scripts/systems/scenario_loader.gd"
Ballistics="*res://scripts/systems/ballistic_physics.gd"
Satellites="*res://scripts/systems/satellite_system.gd"
Damage="*res://scripts/systems/damage_model.gd"
SaveManager="*res://scripts/systems/save_manager.gd"
DetectionManager="*res://scripts/systems/detection_manager.gd"
ScenarioValidator="*res://scripts/systems/scenario_validator.gd"
ScenarioManager="*res://scripts/systems/scenario_manager.gd"
Statistics="*res://scripts/systems/statistics.gd"
CampaignManager="*res://scripts/systems/campaign_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

move_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":65,"key_label":0,"unicode":97,"echo":false,"script":null)
]
}
